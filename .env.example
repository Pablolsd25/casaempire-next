# ── Google Workspace (correos automáticos del sitio) ────────────
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contacto@casaempire.net
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_EMAIL=contacto@casaempire.net
SMTP_FROM_NAME=Casa Empire

# SMTP_PASS = contraseña de aplicación de Google (no la contraseña del buzón).
# Admin de Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones.

# ── Cloudflare R2 (media: imágenes, videos) ───────────────────
# Dashboard → R2 → Create bucket → Public access (custom domain recomendado)
# Dashboard → R2 → Manage R2 API Tokens → Object Read & Write
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=casaempire-media
# URL pública del bucket (custom domain o *.r2.dev). Sin barra final.
NEXT_PUBLIC_R2_PUBLIC_URL=https://media.casaempire.net
